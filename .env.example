# GitHub App credentials
# Create your app at: https://github.com/settings/apps/new
# Required permissions: Pull requests (read/write), Commit statuses (read/write), Contents (read)
GITHUB_APP_ID=12345

# Paste your App's private key PEM (with newlines escaped as \n, or use a multi-line heredoc)
GITHUB_APP_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"

# Webhook secret — set this in both GitHub App settings and here
GITHUB_WEBHOOK_SECRET=your-random-secret-here

# Public keys for registered AI agents (one per agent)
# Key name: PROVENANCE_PUBKEY_<AGENT_ID_UPPERCASED_UNDERSCORED>
# Generate with: provenance-sign pubkey --key signing.key
PROVENANCE_PUBKEY_OPENCLAW_EXECUTOR="-----BEGIN PUBLIC KEY-----\n...\n-----END PUBLIC KEY-----"

# OpenClaw LLM gateway for intent-drift detection (optional)
# If unset, intent-drift check returns UNCLEAR
OPENCLAW_ENDPOINT=http://localhost:8000
OPENCLAW_API_KEY=

# Server port (default: 8080)
PORT=8080
